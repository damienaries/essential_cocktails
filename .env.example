# Firebase (Web app) — from Firebase Console → Project settings → Your apps

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
# Required for admin image uploads. After first deploy, run gsutil cors (see storage-cors-apply.txt).
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Analytics)
VITE_FIREBASE_MEASUREMENT_ID=

# Comma-separated Firebase Auth UIDs allowed to access /admin. Find your UID in
# Firebase Console → Authentication → Users after signing in once.
VITE_ADMIN_UIDS=

# Google Apps Script web app URL that handles contact-form submissions. Deploy
# the script (see src/lib/contactFormSubmit.ts for the expected request shape)
# and paste the published /exec URL here.
VITE_CONTACT_WEBHOOK_URL=
